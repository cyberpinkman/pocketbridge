{
  "name": "pocketbridge",
  "version": "0.1.0",
  "private": true,
  "description": "Local bridge between phone, Mac, PocketInbox, and a personal knowledge base.",
  "type": "module",
  "scripts": {
    "dev": "tsx watch server/src/index.ts",
    "build": "tsc -p tsconfig.json",
    "env:check": "npm run build && node dist/server/src/environmentCheck.js",
    "start": "node dist/server/src/index.js",
    "demo:smoke": "npm run build && node --test --test-concurrency=1 server/test/demo-flow.test.mjs",
    "demo:contract": "npm run build && node --test --test-concurrency=1 server/test/upstream-contract-flow.test.mjs",
    "demo:live": "npm run build && node --test --test-concurrency=1 server/test/live-demo-flow.test.mjs",
    "demo:ble-agent": "npm run build && node dist/server/scripts/ble-agent-demo-check.js",
    "demo:ready": "npm run build && node dist/server/scripts/demo-ready.js",
    "demo:lan-check": "npm run build && node dist/server/scripts/lan-check.js",
    "test": "npm run build && node --test --test-concurrency=1 server/test/*.mjs"
  },
  "dependencies": {
    "cors": "^2.8.5",
    "express": "^4.19.2",
    "multer": "^2.2.0",
    "nanoid": "^5.0.7",
    "qrcode": "^1.5.3",
    "ws": "^8.17.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/multer": "^1.4.11",
    "@types/node": "^20.14.10",
    "@types/qrcode": "^1.5.5",
    "@types/ws": "^8.5.10",
    "tsx": "^4.16.2",
    "typescript": "^5.5.3"
  }
}
