{
  "name": "pocketbridge-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/src/index.js",
    "test": "node --import tsx --test tests/*.test.ts",
    "demo:smoke": "tsx scripts/demo-smoke.ts",
    "demo:ui-smoke": "playwright install chromium && tsx scripts/ui-smoke.ts"
  },
  "dependencies": {
    "chokidar": "^4.0.3",
    "cors": "^2.8.5",
    "express": "^5.1.0",
    "multer": "^2.0.2",
    "nanoid": "^5.1.5",
    "qrcode": "^1.5.4",
    "ws": "^8.18.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.0.7",
    "@types/qrcode": "^1.5.5",
    "@types/ws": "^8.18.1",
    "playwright": "^1.61.1",
    "tsx": "^4.20.3",
    "typescript": "^5.8.3"
  }
}
